{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "useUnknownInCatchVariables": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "app/api/admin/staff/route.ts",
    "app/api/auth/admin-login/route.ts",
    "app/api/auth/forgot-password/route.ts",
    "app/api/auth/login/route.ts",
    "app/api/auth/register/route.ts",
    "app/api/billing/portal/route.ts",
    "app/api/certified-mail/pricing/route.ts",
    "app/api/certified-mail/status/[trackingId]/route.ts",
    "app/api/certified-mail/templates/route.ts",
    "app/api/certified-mail/track/[trackingNumber]/route.ts",
    "app/api/certified-mail/validate-address/route.ts",
    "app/api/compliance/ccpa/route.ts",
    "app/api/compliance/fcra/route.ts",
    "app/api/compliance/gdpr/route.ts",
    "app/api/compliance/hipaa/route.ts",
    "app/api/compliance/notifications/route.ts",
    "app/api/compliance/pci/route.ts",
    "app/api/compliance/retention/route.ts",
    "app/api/compliance/route.ts"
  ]
}