# ============================================================
# Credit Repair App — Environment Variable Reference
# ============================================================
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored and must NEVER be committed.
#
# Required keys are marked [REQUIRED].
# Optional keys may be left blank in development but are
# strongly recommended in production.
# ============================================================

# ──────────────────────────────────────────────────────────
# RUNTIME ENVIRONMENT
# ──────────────────────────────────────────────────────────
NODE_ENV=development                       # development | production | test

# ──────────────────────────────────────────────────────────
# APPLICATION URL  [REQUIRED]
# ──────────────────────────────────────────────────────────
# Full public URL of the app — used in emails, redirects, CORS, and WebSocket fallback.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# WebSocket server URL — required if realtime journey tracking is enabled.
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3001/ws/journey-tracking

# ──────────────────────────────────────────────────────────
# SECURITY  [REQUIRED]
# ──────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d

# Generate with:  openssl rand -hex 32
ENCRYPTION_MASTER_KEY=replace-with-at-least-32-random-characters
INTERNAL_API_SECRET=your-random-secret-here   # [REQUIRED] Protects /api/mlm/rank-check endpoint

# Comma-separated list of allowed CORS origins (production).
# Defaults to NEXT_PUBLIC_APP_URL when not set.
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ──────────────────────────────────────────────────────────
# SUPABASE  [REQUIRED]
# ──────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ──────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/creditrepairdb
NEON_DATABASE_URL=                         # optional Neon fallback

# ──────────────────────────────────────────────────────────
# OPENAI  [REQUIRED for AI features]
# ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key

# ──────────────────────────────────────────────────────────
# STRIPE  [REQUIRED for payments]
# ──────────────────────────────────────────────────────────
# Server-side secret (never exposed to the browser)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Browser-accessible publishable key (NEXT_PUBLIC_ prefix is mandatory)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Webhook signing secret (Stripe dashboard → Webhooks → your endpoint)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs — create these in the Stripe dashboard under Products
STRIPE_BASIC_PRICE_ID=price_your_basic_monthly_id
STRIPE_PREMIUM_PRICE_ID=price_your_premium_monthly_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_monthly_id

# ──────────────────────────────────────────────────────────
# PAYPAL  [REQUIRED if PayPal payouts are enabled]
# ──────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# ──────────────────────────────────────────────────────────
# EMAIL  [REQUIRED — choose one provider]
# ──────────────────────────────────────────────────────────
# Option A: SendGrid (recommended for production)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Option B: SMTP (Gmail or other provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password          # create at myaccount.google.com/apppasswords

# Sender identity
FROM_EMAIL=noreply@your-domain.com
FROM_NAME=Credit Repair App
REPLY_TO_EMAIL=support@your-domain.com

# SendGrid dynamic template IDs (optional — plain-text email is used if not set)
SENDGRID_TEMPLATE_MLM_INVITATION=d-your_template_id
SENDGRID_TEMPLATE_CREDIT_REPAIR_WELCOME=d-your_template_id
SENDGRID_TEMPLATE_ADMIN_NOTIFICATION=d-your_template_id

# ──────────────────────────────────────────────────────────
# SHIPENGINE  [REQUIRED for Certified Mail feature]
# ──────────────────────────────────────────────────────────
SHIPENGINE_API_KEY=your_shipengine_api_key

# ──────────────────────────────────────────────────────────
# MONITORING & LOGGING
# ──────────────────────────────────────────────────────────
SENTRY_DSN=https://your-dsn@sentry.io/project-id
AUDIT_LOGGING_ENABLED=true
LOGGING_SERVICE_URL=https://your-logging-service.com/api/logs
LOGGING_SERVICE_TOKEN=your-logging-token

# ──────────────────────────────────────────────────────────
# RATE LIMITING
# ──────────────────────────────────────────────────────────
RATE_LIMIT_REDIS_URL=redis://localhost:6379
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ──────────────────────────────────────────────────────────
# FILE UPLOADS
# ──────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760                     # 10 MB

# ──────────────────────────────────────────────────────────
# ANALYSIS
# ──────────────────────────────────────────────────────────
ANALYSIS_CONFIDENCE_THRESHOLD=0.7
MAX_ACCOUNTS_PER_REPORT=20
MAX_NEGATIVE_ITEMS_PER_REPORT=10

# ──────────────────────────────────────────────────────────
# FEATURE FLAGS
# ──────────────────────────────────────────────────────────
# Core features — keep true in production
ENABLE_AI_ANALYSIS=true
ENABLE_SUPERIOR_PARSER=true
ENABLE_NOTIFICATIONS=true
ENABLE_AUDIT_LOGGING=true

# Graduated rollout — set to true when ready to ship each feature
ENABLE_NEW_DASHBOARD=false
ENABLE_ADVANCED_ANALYTICS=false
ENABLE_BETA_FEATURES=false
# ENABLE_MLM_V2 — RETIRED. v2 features are now the default.
ENABLE_ENHANCED_COMMISSION=false
ENABLE_NEW_EMAIL_TEMPLATES=false
ENABLE_ADVANCED_EMAIL_ANALYTICS=false
ENABLE_NEW_BILLING_FLOW=false
ENABLE_SUBSCRIPTION_UPGRADES=false

# ──────────────────────────────────────────────────────────
# COMPLIANCE
# ──────────────────────────────────────────────────────────
GDPR_ENABLED=true
FCRA_ENABLED=true
CCPA_ENABLED=true
DATA_RETENTION_ENABLED=true
COMPLIANCE_AUDIT_INTERVAL=30
DATA_RETENTION_REDIS_URL=redis://localhost:6379
COMPLIANCE_WEBHOOK_URL=https://your-compliance-webhook.com

# ──────────────────────────────────────────────────────────
# MLM SYSTEM
# ──────────────────────────────────────────────────────────
MLM_ENABLED=true
# MLM_COMMISSION_RATE — RETIRED. Rates are now defined in lib/mlm-commission-config.ts
MLM_RANK_UPGRADE_THRESHOLD=1000

# ──────────────────────────────────────────────────────────
# PUSH NOTIFICATIONS
# ──────────────────────────────────────────────────────────
PUSH_NOTIFICATION_VAPID_PUBLIC_KEY=your-vapid-public-key
PUSH_NOTIFICATION_VAPID_PRIVATE_KEY=your-vapid-private-key
PUSH_NOTIFICATION_VAPID_SUBJECT=mailto:admin@your-domain.com
